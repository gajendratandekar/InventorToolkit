<Window x:Class="InventorToolkit.ObjectCounter.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Object Counter"
        Height="450"
        Width="420"
        WindowStartupLocation="CenterScreen">

	<Grid Margin="10">
		<DataGrid Name="GridResult"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  VerticalScrollBarVisibility="Auto">

			<DataGrid.Columns>
				<DataGridTextColumn Header="Shape Name" Binding="{Binding Shape}" Width="220"/>
				<DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="120"/>
			</DataGrid.Columns>

		</DataGrid>
	</Grid>
</Window>